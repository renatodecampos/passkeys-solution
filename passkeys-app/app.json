{
  "expo": {
    "name": "passkeys-app",
    "owner": "renatocampos",
    "description": "Passkeys app",
    "sdkVersion": "53.0.0",
    "githubUrl": "https://github.com/renatocampos/passkeys-app",
    "orientation": "portrait",
    "locales": {
      "en": {
        "name": "Passkeys App",
        "description": "Passkeys app"
      },
      "pt-BR": {
        "name": "Passkeys App",
        "description": "Passkeys app"
      }
    },
    "icon": "./assets/images/icon.png",
    "scheme": "passkeysapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.renatocampos.passkeysapp",
      "buildNumber": "1.0.0",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.renatocampos.passkeysapp",
      "versionCode": 1,
      "softwareKeyboardLayoutMode": "resize"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "dff18db2-78cd-4c78-bf2d-b53fb630f368"
      }
    }
  }
}
