{
  "expo": {
    "name": "Passkey Demo",
    "owner": "renatocampos",
    "description": "Passkeys app",
    "sdkVersion": "53.0.0",
    "githubUrl": "https://github.com/renatocampos/passkeys-app",
    "orientation": "portrait",
    "locales": {
      "en": {
        "name": "Passkey Demo",
        "description": "Passkeys app"
      },
      "pt-BR": {
        "name": "Passkey Demo",
        "description": "Passkeys app"
      }
    },
    "icon": "./assets/images/icon.png",
    "backgroundColor": "#F8FAFC",
    "scheme": "passkeysapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.renatocampos.passkeysapp",
      "buildNumber": "1.0.0",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#F8FAFC"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.renatocampos.passkeysapp",
      "versionCode": 1,
      "softwareKeyboardLayoutMode": "resize"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "./plugins/withAndroidUserCA.js",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F8FAFC",
          "android": {
            "image": "./assets/images/splash-android.png",
            "imageWidth": 288,
            "resizeMode": "contain"
          }
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "dff18db2-78cd-4c78-bf2d-b53fb630f368"
      }
    }
  }
}
