# Server Configuration
PORT=3000
HOST=0.0.0.0

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=passkeys

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# WebAuthn Configuration
RP_ID=localhost
RP_NAME="Passkeys Server"
RP_ORIGIN=http://localhost:3000

# Session Configuration
SESSION_SECRET=your-session-secret-key
SESSION_TTL=86400 # 24 hours in seconds

# Logging Configuration
LOG_LEVEL=info # Options: error, warn, info, debug

# Registration Configuration
REGISTRATION_TIMEOUT=60000 # 1 minute in milliseconds

# Security
RATE_LIMIT_MAX=100
RATE_LIMIT_TIME_WINDOW="1 minute"

# Keystore binding + auth audit (RFC-0004)
# Deny session when binding reports lost (PoC: usually false)
AUTH_DENY_ON_BINDING_LOST=true
# Deny session when binding was unlocked with device PIN instead of biometric
AUTH_DENY_ON_BINDING_PIN_UNLOCK=true
# Max failed auth attempts per userId per 5-min window before 429
AUTH_RATE_LIMIT_MAX=3
# Optional: override collection names
# AUTH_ATTEMPTS_COLLECTION=auth_attempts
# KEYSTORE_BINDING_COLLECTION=keystore_binding
# BINDING_CHALLENGE_TTL_SECONDS=300